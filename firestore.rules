rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // items - ใครก็อ่านได้ แต่เขียนไม่ได้จาก client
    // (admin ต้องเข้าผ่านหน้า admin ที่ตรวจ password แล้ว
    //  ตอนนี้ยังเปิด write เพราะยังไม่มี Firebase Auth)
    match /items/{itemId} {
      allow read: if true;
      allow write: if true;

      // stockHistory subcollection
      match /stockHistory/{historyId} {
        allow read: if true;
        allow create: if true;
      }
    }

    // orders - สร้างได้ต้องมี field ครบ, อ่านได้, อัพเดทได้
    match /orders/{orderId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['facebook', 'characterName', 'items', 'totalPrice', 'status'])
                    && request.resource.data.facebook is string
                    && request.resource.data.facebook.size() > 0
                    && request.resource.data.characterName is string
                    && request.resource.data.characterName.size() > 0
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.totalPrice is number
                    && request.resource.data.totalPrice > 0
                    && request.resource.data.status == 'pending';
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                    && request.resource.data.status in ['pending', 'completed', 'cancelled'];
    }

    // settings - อ่านได้อย่างเดียว (เปลี่ยนผ่าน Firebase Console เท่านั้น)
    match /settings/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
